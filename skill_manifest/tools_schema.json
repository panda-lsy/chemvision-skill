{
  "openapi": "3.1.0",
  "info": {
    "title": "ChemVision Agent Skill",
    "description": "AI 化学家智能体 - 化学工具调用 API",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://localhost:8899",
      "description": "本地服务"
    }
  ],
  "paths": {
    "/api/chat": {
      "post": {
        "summary": "Agent 对话",
        "description": "与化学智能体对话，Agent 自动决定调用哪些工具",
        "operationId": "chat",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "message": {
                    "type": "string",
                    "description": "用户输入文本"
                  },
                  "history": {
                    "type": "array",
                    "items": {
                      "type": "object",
                      "properties": {
                        "role": { "type": "string" },
                        "content": { "type": "string" }
                      }
                    },
                    "description": "对话历史"
                  },
                  "image_base64": {
                    "type": "string",
                    "description": "图片 base64 编码（多模态）"
                  }
                },
                "required": ["message"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Agent 回复",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "reply": { "type": "string" },
                    "tool_calls": { "type": "array" },
                    "rounds": { "type": "integer" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/tools/call": {
      "post": {
        "summary": "直接调用工具",
        "description": "跳过 Agent，直接调用指定工具",
        "operationId": "callTool",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "tool_name": {
                    "type": "string",
                    "enum": ["name_to_structure", "inspect_smiles", "safety_info", "predict_reaction", "ocr_chemistry"]
                  },
                  "arguments": {
                    "type": "object"
                  }
                },
                "required": ["tool_name", "arguments"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "工具执行结果",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": { "type": "boolean" },
                    "result": { "type": "object" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/tools/list": {
      "get": {
        "summary": "列出工具",
        "operationId": "listTools",
        "responses": {
          "200": {
            "description": "工具列表",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "tools": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "name": { "type": "string" },
                          "description": { "type": "string" },
                          "parameters": { "type": "object" }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/health": {
      "get": {
        "summary": "健康检查",
        "operationId": "health",
        "responses": {
          "200": {
            "description": "服务状态",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "status": { "type": "string" },
                    "model": { "type": "string" },
                    "tools_count": { "type": "integer" }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
